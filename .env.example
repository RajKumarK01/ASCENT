# Copy to .env and fill in. NEVER commit .env.

# --- Existing Foundry project (already created, used for both local dev and azd provision) ---
AZURE_AI_PROJECT_ENDPOINT=your-foundry-project-endpoint
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# --- Existing Azure AI Search (knowledge base) ---
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KNOWLEDGE_BASE=ascent-kb
AZURE_SEARCH_API_KEY=your-search-api-key

# --- YouTube video recommendations ---
# Optional. When set, the /api/employee/study/youtube endpoint uses the
# YouTube Data API v3 for live search results.
# Without a key, ASCENT falls back to a curated skill-to-video mapping.
# Get a free key at: https://console.developers.google.com/
# Alternatively, install youtube-mcp-server (needs same key):
#   npm install -g zubeid-youtube-mcp-server
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# --- Microsoft Graph (Outlook calendar — separate TEST tenant) ---
# App-only (client credentials). Register an app IN THE TEST TENANT, grant the
# Calendars.ReadWrite APPLICATION permission, and grant admin consent. The button
# on the Study Plan page then creates study/assessment events (marked Busy) on the
# configured sample mailbox. Leave these blank to fall back to a downloadable .ics.
GRAPH_TENANT_ID=your-test-tenant-id
GRAPH_CLIENT_ID=your-test-tenant-app-client-id
GRAPH_CLIENT_SECRET=your-test-tenant-app-client-secret
GRAPH_DEFAULT_USER=sample-user@yourtesttenant.onmicrosoft.com
# IANA/Windows timezone name used for event times (e.g. "UTC", "India Standard Time").
GRAPH_TIMEZONE=UTC

# --- Runtime ---
# Set to "local" to force deterministic fallbacks (no Azure calls).
ASCENT_MODE=local
