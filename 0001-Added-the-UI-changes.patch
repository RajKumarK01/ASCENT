+# Foundry Hosted Agent manifest.
+# Declares the protocol(s) the container exposes and any non-secret env vars.
+# Secrets are pulled from a Foundry project connection at sandbox start:
+#   value: ${{connections.<connection-name>.credentials.<field>}}
+name: ascent-agent
+description: ASCENT multi-agent enterprise learning system (synthetic demo data only).
+
+# Protocols the container serves. Responses = conversational, multi-turn.
+container_protocol_versions:
+  - responses
+
+environment_variables:
+  - name: AZURE_AI_MODEL_DEPLOYMENT
+    value: gpt-4o
+  - name: ASCENT_MODE
+    value: foundry
+  # Platform auto-injects FOUNDRY_PROJECT_ENDPOINT, APPLICATIONINSIGHTS_CONNECTION_STRING, etc.
+  # Example secret reference (create the connection before deploying):
+  # - name: AZURE_SEARCH_ENDPOINT
+  #   value: ${{connections.ascent-search.target}}
